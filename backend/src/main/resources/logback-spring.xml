<?xml version="1.0" encoding="UTF-8"?>
<!--
  AltarWed logging config. Console only. Azure App Service tails stdout into
  App Insights / Log Stream. No file appenders (App Service disks are ephemeral
  and per-instance; the pipeline is the source of truth).

  Timestamps (issue #294): our %d is pinned to America/New_York for human
  readability, with the zone abbreviation printed so the DST fall-back hour is
  unambiguous. This is display-only; the JVM stays on UTC (never set
  WEBSITE_TIME_ZONE / TZ on the App Service, it shifts every LocalDateTime.now()
  in the app while the DB and existing rows stay UTC). The Log Stream shows a
  second, leading UTC timestamp on every line; that is the fixed Docker
  container-log prefix Azure adds outside our process and it cannot be
  suppressed from app config. Query App Insights / Kusto when you want a single
  chosen display timezone.

  Pattern includes %X{requestId} so every line in App Insights can be filtered
  back to one HTTP request. requestId is populated by RequestIdFilter and
  propagated across @Async via MdcTaskDecorator on the emailExecutor.

  When adding JSON-structured ingest later: add logstash-logback-encoder as a
  dependency and swap the encoder element. The MDC fields are already there.
-->
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS zzz, America/New_York} %5p [%t] [requestId=%X{requestId:-none}] %logger{36} - %msg%n%wEx"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!--
      Async wrapper keeps logging off the request thread under bursty load.

      neverBlock=false (default): when the queue is full, the calling thread blocks
      until there's room. This is the correct choice for an audit log; silently
      dropping security/auth events would defeat the whole point. The trade-off is
      that a logging backpressure spike will slow request handling, which is
      acceptable because the alternative is losing the evidence that we needed the
      logs in the first place.

      discardingThreshold=0 means "never auto-discard INFO/DEBUG when 80% full" -
      again, audit-preserving over throughput-preserving.

      queueSize=2048 (4x default) gives more headroom before any of the above kicks in.
    -->
    <appender name="ASYNC_CONSOLE" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="CONSOLE"/>
        <queueSize>2048</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <neverBlock>false</neverBlock>
        <includeCallerData>false</includeCallerData>
    </appender>

    <!-- Hibernate query firehose: turn down to WARN in prod, override locally if debugging SQL. -->
    <logger name="org.hibernate.SQL" level="WARN"/>
    <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="WARN"/>

    <!-- Tomcat / Spring boilerplate: keep at INFO so startup banner + lifecycle events show. -->
    <logger name="org.apache.catalina" level="INFO"/>
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="org.springframework.security" level="INFO"/>

    <!-- Our code: INFO baseline. Per-package overrides via spring profile or env var. -->
    <logger name="com.altarwed" level="INFO"/>

    <root level="INFO">
        <appender-ref ref="ASYNC_CONSOLE"/>
    </root>

    <!-- Local profile: louder console for development. -->
    <springProfile name="local">
        <logger name="com.altarwed" level="DEBUG"/>
        <logger name="org.hibernate.SQL" level="DEBUG"/>
    </springProfile>
</configuration>
