# Resend, email capture for waitlist
# Sign up at resend.com, go to API Keys, and create one.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_AUDIENCE_ID=your-audience-id-from-resend-dashboard

# Backend API (leave empty until the backend is deployed)
NEXT_PUBLIC_API_URL=https://api.altarwed.com

# Facebook Pixel, get this from Meta Business Manager → Events Manager → your Pixel → Settings
# Leave blank locally; set in Azure Static Web Apps environment variables for production
NEXT_PUBLIC_FB_PIXEL_ID=

# Cloudflare Turnstile site key (public by design), guards the RSVP find-invitation
# search against scripted enumeration (issue #89). Create a site at
# dash.cloudflare.com -> Turnstile -> Add site (widget mode: Managed). Leave blank
# locally; without it the widget doesn't render and the backend (also unconfigured
# via TURNSTILE_SECRET_KEY) verifies every request rather than breaking the feature.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
